# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME="ASSOCHAM AI Contact Intelligence Platform"
APP_VERSION="2.0.0"
ENVIRONMENT="development"
DEBUG=true

# ── Server ────────────────────────────────────────────────────────────────────
HOST="0.0.0.0"
PORT=8000

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"

# ── Data source ───────────────────────────────────────────────────────────────
# "mock" = in-memory dev data
# "google_sheets" = live Google Sheets
DATA_SOURCE="google_sheets"

# ── Google Sheets ─────────────────────────────────────────────────────────────
GOOGLE_SHEETS_SPREADSHEET_ID="your-spreadsheet-id-from-url"
# Paste the full service account JSON as a single-line string, or provide a file path
GOOGLE_SHEETS_CREDENTIALS_JSON='{"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}'
GOOGLE_SHEETS_CONTACTS_SHEET_NAME="Contacts"
GOOGLE_SHEETS_USERS_SHEET_NAME="Users"
GOOGLE_SHEETS_AUDIT_SHEET_NAME="AuditLog"

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET="replace-with-64-char-random-hex-string"
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── Gemini AI ─────────────────────────────────────────────────────────────────
GEMINI_API_KEY="your-gemini-api-key"
GEMINI_MODEL="gemini-2.5-flash"
